<div class="notfound">
  <div class="notfound-badge">404 · Not Found</div>
  <div class="notfound-num" aria-hidden="true">404</div>
  <h1 class="notfound-title">这里什么都没有</h1>
  <p class="notfound-bio">
    你要找的页面可能已经搬家、改名，或者从来就没存在过。
  </p>
  <div class="notfound-actions">
    <a href="<%- url_for('/') %>" class="link-btn">回到首页</a>
    <a href="<%- url_for('/archives/') %>" class="link-btn link-btn-ghost">Writing</a>
    <a href="<%- url_for('/projects/') %>" class="link-btn link-btn-ghost">Projects</a>
  </div>
  <%
    var repoCfg404 = theme.footer && theme.footer.repo;
    var repoUrl404 = repoCfg404 && repoCfg404.url;
    if (repoUrl404 && repoUrl404.charAt(repoUrl404.length - 1) === '/') repoUrl404 = repoUrl404.slice(0, -1);
    var issuesUrl404 = (repoCfg404 && repoCfg404.issues) || (repoUrl404 ? repoUrl404 + '/issues' : 'https://github.com/misterrabbit0w0/misterrabbit0w0.github.io/issues');
  %>
  <div class="notfound-hint">
    若你认为这是个 bug，可以到
    <a href="<%= issuesUrl404 %>" target="_blank" rel="noopener noreferrer">GitHub Issues</a>
    留言。
  </div>
</div>
