<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%
  if (page.title && !is_home()) { %><%= page.title %> — <%= config.title %><% }
  else { %><%= config.title %><% if (config.subtitle) { %> — <%= config.subtitle %><% } %><% }
%></title>
<%# open_graph 会输出 description、og:* 与 twitter:card；文章页自动取正文首图，其余页面用头像兜底 %>
<%- open_graph(is_post() ? {} : { image: full_url_for((theme.brand && theme.brand.avatar) || '/favicon-32.png') }) %>
<% if (config.keywords) { %>
<meta name="keywords" content="<%= config.keywords %>">
<% } %>
<meta name="theme-color" content="#f9a8d4" media="(prefers-color-scheme: light)">
<meta name="theme-color" content="#221f2b" media="(prefers-color-scheme: dark)">
<link rel="alternate" type="application/atom+xml" href="<%- url_for('/atom.xml') %>" title="<%= config.title %>">
<link rel="icon" href="<%- url_for('/favicon.svg') %>" type="image/svg+xml">
<link rel="icon" href="<%- url_for('/favicon.ico') %>" sizes="any">
<link rel="icon" href="<%- url_for('/favicon-32.png') %>" type="image/png" sizes="32x32">
<link rel="icon" href="<%- url_for('/favicon-16.png') %>" type="image/png" sizes="16x16">
<link rel="apple-touch-icon" href="<%- url_for('/apple-touch-icon.png') %>" sizes="180x180">
<%# Maple Mono CN（中文网字计划 cn-font-split 子集，按 unicode-range 懒加载）%>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@chinese-fonts/maple-mono-cn@2.0.0/dist/MapleMono-CN-Regular/result.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@chinese-fonts/maple-mono-cn@2.0.0/dist/MapleMono-CN-Italic/result.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@chinese-fonts/maple-mono-cn@2.0.0/dist/MapleMono-CN-Bold/result.css">
<link rel="stylesheet" href="<%- url_for('/css/shared.css') %>">
<link rel="stylesheet" href="<%- url_for('/css/page.css') %>">
