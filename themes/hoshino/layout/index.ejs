<%
  var hero = theme.hero || {};
  var posts = site.posts.sort('-date').toArray();
  var recent = posts.slice(0, 8);

  function fmt(date) {
    var d = new Date(date);
    return d.getFullYear() + ' · ' + String(d.getMonth()+1).padStart(2,'0') + ' · ' + String(d.getDate()).padStart(2,'0');
  }
  function excerptOf(post) {
    if (post.excerpt) return post.excerpt.replace(/<[^>]+>/g, '').trim().substring(0, 100);
    return (post.content || '').replace(/<[^>]+>/g, '').trim().substring(0, 100);
  }
  function readTime(post) {
    var text = (post.content || '').replace(/<[^>]+>/g, '');
    return Math.max(1, Math.round(text.length / 3 / 200)) + ' min';
  }
%>

<div class="home-layout">
  <div class="home-main">
    <section class="hero hero-home">
      <div class="hero-text">
        <% if (hero.handle) { %><div class="handle"><%= hero.handle %></div><% } %>
        <h1><%= hero.title_prefix || '你好，我是' %> <%= hero.title_name || config.author %></h1>
        <% if (hero.bio) { %><p class="bio"><%- hero.bio %></p><% } %>
        <div class="hero-tags">
          <% (hero.tags || []).forEach(function(t) { %>
            <span class="tag <%= t.class || 'tag-pink' %>"><%= t.text %></span>
          <% }); %>
        </div>
        <div class="social-row">
          <% (theme.social || []).forEach(function(s) { %>
            <a href="<%= s.url %>" class="social-btn" target="_blank" rel="noopener">
              <%- partial('_partial/icon', { name: s.icon, size: 15, className: 'social-icon' }) %>
              <%= s.name %>
            </a>
          <% }); %>
        </div>
      </div>
    </section>

    <% if (recent.length > 0) { %>
    <section class="home-writing">
      <div class="sec-header">
        <div class="sec-title">最近文章</div>
        <a href="<%- url_for('/archives/') %>" class="sec-more">全部文章</a>
      </div>
      <div class="article-list article-list-home">
        <% recent.forEach(function(p) {
          var firstCat = p.categories && p.categories.length ? p.categories.first().name : null;
          var tagArr = p.tags ? p.tags.toArray().map(function(t){ return t.name; }) : [];
        %>
        <a href="<%- url_for(p.path) %>" class="article-row">
          <div class="article-row-body">
            <div class="article-row-title"><%= p.title %></div>
            <div class="article-row-excerpt"><%= excerptOf(p) %>…</div>
            <div class="article-row-meta">
              <span class="article-row-date"><%= fmt(p.date) %></span>
              <% if (firstCat) { %><span class="tag <%= cat_tag_class(firstCat) %>"><%= firstCat %></span><% } %>
              <% tagArr.slice(0, 2).forEach(function(t) { %>
                <span class="tag-text">#<%= t %></span>
              <% }); %>
            </div>
          </div>
          <div class="article-row-right">
            <span class="read-time"><%= readTime(p) %></span>
          </div>
        </a>
        <% }); %>
      </div>
    </section>
    <% } %>
  </div>

  <aside class="widgets-column home-widgets">
    <%- partial('_partial/widgets') %>
  </aside>
</div>
