<!DOCTYPE html>
<html lang="<%= config.language || 'zh-CN' %>">
<head>
  <%- partial('_partial/head') %>
</head>
<body class="<%= is_home() || is_post() || is_archive() ? 'has-sidebar' : '' %>">

<% if (is_post()) { %><div id="read-progress"></div><% } %>
<div class="petals" id="petals"></div>

<div class="page<%= (is_home() || is_post() || is_archive()) ? ' page-wide' : '' %>">
  <%- partial('_partial/nav') %>

  <%- body %>

  <%- partial('_partial/footer') %>
</div>

<%- partial('_partial/tweaks') %>

<script src="<%- url_for('/js/shared.js') %>"></script>
<%
  var githubUser = 'misterrabbit0w0';
  (theme.social || []).forEach(function(s) {
    if (s.icon === 'github' && s.url) {
      var u = s.url;
      if (u.charAt(u.length - 1) === '/') u = u.slice(0, -1);
      githubUser = u.split('/').pop() || githubUser;
    }
  });
%>
<script>
  initShared({
    petalCount: <%= theme.effects && theme.effects.petals || 12 %>,
    themeMode: '<%= (theme.effects && theme.effects.theme) || "system" %>',
    statusCard: {
      enable: <%= !!(theme.hero && theme.hero.status_card && theme.hero.status_card.enable) %>,
      discordId: '<%= (theme.hero && theme.hero.status_card && theme.hero.status_card.discord_id) || "" %>',
      username: '<%= githubUser %>',
      location: '<%= (theme.hero && theme.hero.status_card && theme.hero.status_card.location) || "织星阁" %>',
      defaultAct: '<%= (theme.hero && theme.hero.status_card && theme.hero.status_card.default_act) || "编织星光中..." %>',
      defaultDetail: '<%= (theme.hero && theme.hero.status_card && theme.hero.status_card.default_detail) || "misterrabbit0w0.github.io" %>'
    }
  });
</script>
</body>
</html>
