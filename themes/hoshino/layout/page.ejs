<%
  // page.layout 可为 about | projects | 默认
  var layout = page.layout || 'page';
%>

<% if (layout === 'projects') { %>
  <% var p = theme.projects || {};
     var featured = p.featured || null;
     var cards = p.cards || [];
     var archive = p.archive || [];
     var allCats = {};
     cards.forEach(function(c) { if (c.cat) allCats[c.cat] = true; });
     var catList = Object.keys(allCats);
  %>
  <div class="page-hero" style="display:block">
    <h1 style="font-size:32px;font-weight:700;margin-bottom:8px">我的项目</h1>
    <p style="font-size:14px;color:var(--muted);font-weight:300"><%= page.description || '用代码构建有趣的东西' %></p>
  </div>

  <% if (catList.length > 0) { %>
  <div class="filter-bar">
    <button class="filter-btn active" data-cat="all">全部</button>
    <% catList.forEach(function(c) { %>
      <button class="filter-btn" data-cat="<%= c %>"><%= c %></button>
    <% }); %>
  </div>
  <% } %>

  <% if (featured) { %>
  <div class="project-featured">
    <div>
      <div class="project-featured-badge">✦ 精选项目</div>
      <h2><%= featured.name %></h2>
      <p><%- featured.desc %></p>
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px">
        <% (featured.tags || []).forEach(function(t, i) {
          var cls = ['tag-lav','tag-pink','tag-mint','tag-gold'][i % 4];
        %>
          <span class="tag <%= cls %>"><%= t %></span>
        <% }); %>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <% (featured.links || []).forEach(function(l) { %>
          <a href="<%- url_for(l.url) %>" class="link-btn<% if (!l.primary) { %> link-btn-ghost<% } %>"<% if (/^https?:/.test(l.url)) { %> target="_blank" rel="noopener"<% } %>><%= l.text %></a>
        <% }); %>
      </div>
    </div>
    <div class="project-icon-big"<% if (featured.cover) { %> style="background-image:url('<%- url_for(featured.cover) %>')"<% } %>>
      <% if (!featured.cover) { %><span><%= (featured.name || '').charAt(0) %></span><% } %>
    </div>
  </div>
  <% } %>

  <% if (cards.length > 0) { %>
  <div class="projects-grid" id="projects-grid">
    <% cards.forEach(function(c) { %>
      <a href="<%- c.url ? url_for(c.url) : '#' %>" class="project-card" data-cat="<%= c.cat || '' %>"<% if (c.url && /^https?:/.test(c.url)) { %> target="_blank" rel="noopener"<% } %>>
        <div class="project-card-header">
          <div class="project-icon"<% if (c.cover) { %> style="background-image:url('<%- url_for(c.cover) %>')"<% } %>>
            <% if (!c.cover) { %><span><%= (c.name || '').charAt(0) %></span><% } %>
          </div>
          <div>
            <div class="project-name"><%= c.name %></div>
            <% if (c.stars) { %><div style="font-size:12px;color:var(--muted)">★ <%= c.stars %></div><% } %>
          </div>
        </div>
        <div class="project-desc"><%- c.desc %></div>
        <div class="project-footer">
          <div class="project-stats">
            <% if (c.lang) { %><span class="project-stat"><span class="lang-dot" style="background:<%= c.lang_color || '#c4b5fd' %>"></span><%= c.lang %></span><% } %>
          </div>
          <div class="project-links">
            <% (c.links || []).forEach(function(l) { %>
              <span class="project-link"><%= l.text %></span>
            <% }); %>
          </div>
        </div>
      </a>
    <% }); %>
  </div>
  <% } %>

  <% if (archive.length > 0) { %>
    <div class="divider"></div>
    <div class="archive-title">其他小项目</div>
    <div class="archive-grid">
      <% archive.forEach(function(a) { %>
        <a href="<%- a.url ? url_for(a.url) : '#' %>" class="archive-card"<% if (a.url && /^https?:/.test(a.url)) { %> target="_blank" rel="noopener"<% } %>>
          <div class="archive-card-name">✦ <%= a.name %></div>
          <div class="archive-card-desc"><%- a.desc %></div>
        </a>
      <% }); %>
    </div>
  <% } %>

  <% if (page.content && page.content.trim()) { %>
    <div class="divider"></div>
    <div class="post-body"><%- page.content %></div>
  <% } %>

  <script>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = btn.dataset.cat;
      document.querySelectorAll('#projects-grid .project-card').forEach(card => {
        card.style.display = (cat === 'all' || card.dataset.cat === cat) ? '' : 'none';
      });
    });
  });
  </script>

<% } else if (layout === 'about') { %>
  <% var a = theme.about || {};
     var s = a.sections || {};
  %>
  <div class="about-hero">
    <div class="about-avatar-wrap">
      <div class="about-avatar-ring">
        <div class="about-avatar-inner">
          <% if (theme.brand && theme.brand.avatar) { %>
            <img src="<%- url_for(theme.brand.avatar) %>" alt="<%= a.name || config.author %>">
          <% } else { %>
            <span><%= ((a.name || config.author || 'A').charAt(0)) %></span>
          <% } %>
        </div>
      </div>
    </div>
    <div>
      <div class="about-hero-name"><%= a.name || config.author %></div>
      <% if (a.handle) { %><div class="about-hero-handle"><%= a.handle %></div><% } %>
      <% if (a.bio) { %><p class="about-hero-bio"><%- a.bio %></p><% } %>
      <div class="about-tags">
        <% (a.tags || []).forEach(function(t) { %>
          <span class="tag <%= t.class || 'tag-pink' %>"><%= t.text %></span>
        <% }); %>
      </div>
      <% if ((theme.social || []).length > 0) { %>
      <div class="social-grid">
        <% theme.social.forEach(function(ss) { %>
          <a href="<%= ss.url %>" class="social-btn" target="_blank" rel="noopener">
            <% if (ss.icon === 'github') { %>
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            <% } else if (ss.icon === 'mail') { %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <% } %>
            <%= ss.name %>
          </a>
        <% }); %>
      </div>
      <% } %>
    </div>
  </div>

  <% if (s.intro) { %>
  <div class="about-section">
    <h2><%= s.intro.title || '关于我' %></h2>
    <% (s.intro.paragraphs || []).forEach(function(p) { %>
      <p><%- p %></p>
    <% }); %>
  </div>
  <% } %>

  <% if ((a.skills || []).length > 0) { %>
  <div class="divider"></div>
  <div class="about-section">
    <h2>技术栈</h2>
    <div class="skills-grid">
      <% a.skills.forEach(function(sk) { %>
        <div class="skill-card">
          <div class="skill-category"><%= sk.category %></div>
          <div class="skill-list">
            <% (sk.items || []).forEach(function(it) { %>
              <span class="skill-pill"><%= it %></span>
            <% }); %>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
  <% } %>

  <% if ((a.timeline || []).length > 0) { %>
  <div class="divider"></div>
  <div class="about-section">
    <h2>成长轨迹</h2>
    <div class="timeline">
      <% a.timeline.forEach(function(t) { %>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-year"><%= t.year %></div>
          <div class="timeline-title"><%= t.title %></div>
          <% if (t.desc) { %><div class="timeline-desc"><%- t.desc %></div><% } %>
        </div>
      <% }); %>
    </div>
  </div>
  <% } %>

  <% if (page.content && page.content.trim()) { %>
    <div class="divider"></div>
    <div class="post-body"><%- page.content %></div>
  <% } %>

<% } else { %>
  <!-- 默认 page 布局：渲染 markdown 内容 -->
  <div class="post-layout" style="grid-template-columns:1fr">
    <article>
      <div class="post-header">
        <h1><%= page.title %></h1>
      </div>
      <div class="post-body"><%- page.content %></div>
    </article>
  </div>
<% } %>
